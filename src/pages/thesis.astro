---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import { Content as ThesisBody, frontmatter as thesis } from '../content/pages/thesis-page.md';
import calibration from '../assets/thesis/calibration.png';
import ellipsoids from '../assets/thesis/ellipsoids.png';

// BibTeX from the Cite block in src/content/pages/thesis-page.md.
const citation = `@thesis{vanni2026geometric,
  author      = {Vanni, Leonardo},
  title       = {Geometrically-Grounded Uncertainty Quantification
                 for Foundational 3D Vision Models},
  school      = {Bocconi University},
  year        = {2026},
  type        = {BSc thesis},
  note        = {Supervisor: Alessandro Pigati}
}`;

const thesisJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Thesis',
  name: thesis.title,
  author: {
    '@type': 'Person',
    name: 'Leonardo Vanni',
    url: 'https://www.leonardovanni.com',
  },
  sourceOrganization: {
    '@type': 'CollegeOrUniversity',
    name: thesis.institution,
  },
  datePublished: String(thesis.year),
});
---

<Base title="Thesis — Leonardo Vanni" description={thesis.description}>
  <script type="application/ld+json" is:inline slot="head" set:html={thesisJsonLd} />

  <header class="max-w-[72ch]">
    <h1 class="font-heading text-3xl font-semibold text-balance">{thesis.title}</h1>
    <p class="mt-4 font-mono text-xs tracking-wide text-muted">
      {thesis.kind} · {thesis.institution} · {thesis.year} · Supervisor: {thesis.supervisor}
    </p>
    <a
      href={thesis.pdf}
      class="mt-6 inline-block rounded-lg bg-accent px-5 py-2.5 font-medium text-bg hover:bg-text"
    >
      Download thesis (PDF)
    </a>
  </header>

  <div class="prose mt-10">
    <ThesisBody />
  </div>

  <figure class="mt-10 max-w-[72ch]">
    <Image src={calibration} alt="Calibration plot" class="rounded-lg border border-border" />
    <figcaption class="mt-2 text-sm text-muted">
      Temperature scaling (T = 3.33) aligns the empirical Mahalanobis CDF with the theoretical
      chi-squared ideal.
    </figcaption>
  </figure>

  <figure class="mt-10 max-w-[72ch]">
    <Image src={ellipsoids} alt="Uncertainty ellipsoid render" class="rounded-lg border border-border" />
    <figcaption class="mt-2 text-sm text-muted">
      Predicted translational uncertainty grows with distance from the reference camera and aligns
      with COLMAP's analytical covariance axes.
    </figcaption>
  </figure>

  <section class="mt-12 max-w-[72ch]">
    <h2 class="font-heading text-2xl font-semibold">Cite</h2>
    <pre
      class="mt-4 overflow-x-auto rounded-lg border border-border bg-surface p-4 font-mono text-[0.8rem] leading-relaxed"><code>{citation}</code></pre>
  </section>
</Base>
