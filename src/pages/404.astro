---
import Base from '../layouts/Base.astro';
---

<Base title="Page not found — Leonardo Vanni" description="Page not found.">
  <section class="py-16">
    <p class="font-mono text-xs tracking-widest text-muted uppercase">404</p>
    <h1 class="mt-3 font-heading text-3xl font-semibold">Page not found</h1>
    <p class="mt-4 max-w-[50ch] text-muted">
      The page you are looking for does not exist or has moved.
    </p>
    <a
      href="/"
      class="mt-8 inline-block rounded-lg border border-border px-5 py-2.5 text-sm hover:border-accent"
    >
      Back to the homepage
    </a>
  </section>
</Base>
