---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { Content as NotesIntro, frontmatter } from '../../content/pages/notes-index.md';

const notes = (await getCollection('notes', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<Base title="Notes — Leonardo Vanni" description={frontmatter.description}>
  <h1 class="font-heading text-3xl font-semibold">{frontmatter.title}</h1>

  {/* Intro sentence (doubles as the empty state — no dummy posts). */}
  <div class="prose mt-6 text-muted">
    <NotesIntro />
  </div>

  {
    notes.length > 0 && (
      <ul class="mt-8 grid max-w-[72ch] gap-4">
        {notes.map((note) => (
          <li class="rounded-lg border border-border bg-surface p-5 hover:border-accent">
            <a href={`/notes/${note.id}/`} class="font-heading text-lg font-semibold">
              {note.data.title}
            </a>
            <time
              datetime={note.data.date.toISOString().slice(0, 10)}
              class="mt-1 block font-mono text-xs text-muted"
            >
              {note.data.date.toISOString().slice(0, 10)}
            </time>
            <p class="mt-2 text-sm text-muted">{note.data.description}</p>
          </li>
        ))}
      </ul>
    )
  }
</Base>
