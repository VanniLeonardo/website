---
/*
  Placeholder portrait. The owner adds the real photo himself.

  TO SWAP IN THE REAL PHOTO:
  1. Drop the file at src/assets/photo.jpg (do not commit anything else).
  2. Replace this component's markup with the following, uncommented:

  ---
  import { Image } from 'astro:assets';
  import photo from '../assets/photo.jpg';
  ---
  <Image
    src={photo}
    alt="Portrait of Leonardo Vanni"
    width={480}
    height={480}
    class="aspect-square w-full rounded-lg border border-border object-cover"
  />

  (astro:assets emits explicit width/height, so no layout shift.)
*/
---

<div
  class="flex aspect-square w-full items-center justify-center rounded-lg border border-border bg-surface"
  aria-hidden="true"
>
  <span class="font-heading text-4xl font-medium tracking-wide text-muted">LV</span>
</div>
