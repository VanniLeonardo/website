---
// Static inline SVG motif: sparse point cloud, two camera frusta, one faint
// uncertainty ellipsoid. 1px strokes, no animation. Kept well under 4 KB.
---

<svg
  viewBox="0 0 520 340"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-label="Stylized 3D reconstruction: point cloud, camera frusta, uncertainty ellipsoid"
  fill="none"
  stroke-width="1"
>
  <!-- camera frustum 1 (top left) -->
  <g stroke="var(--muted)" opacity="0.55">
    <path d="M52 64 148 36M52 64 196 58M52 64 136 108M52 64 184 130"></path>
    <path d="M148 36 196 58 184 130 136 108Z"></path>
  </g>

  <!-- camera frustum 2 (bottom right) -->
  <g stroke="var(--muted)" opacity="0.55">
    <path d="M478 296 372 236M478 296 424 222M478 296 384 300M478 296 436 286"></path>
    <path d="M372 236 424 222 436 286 384 300Z"></path>
  </g>

  <!-- observation rays -->
  <g stroke="var(--border)">
    <path d="M196 58 262 131M424 222 296 182"></path>
  </g>

  <!-- uncertainty ellipsoid (silhouette + equator) -->
  <g stroke="var(--muted)" transform="rotate(-14 276 178)">
    <ellipse cx="276" cy="178" rx="86" ry="52" opacity="0.3" stroke-dasharray="4 5"></ellipse>
    <ellipse cx="276" cy="178" rx="86" ry="18" opacity="0.18" stroke-dasharray="4 5"></ellipse>
  </g>

  <!-- sparse point cloud -->
  <g fill="var(--muted)" stroke="none">
    <circle cx="232" cy="150" r="1.5" opacity="0.5"></circle>
    <circle cx="251" cy="138" r="1.5" opacity="0.8"></circle>
    <circle cx="268" cy="128" r="1.5" opacity="0.6"></circle>
    <circle cx="287" cy="134" r="1.5" opacity="0.9"></circle>
    <circle cx="305" cy="143" r="1.5" opacity="0.5"></circle>
    <circle cx="321" cy="158" r="1.5" opacity="0.7"></circle>
    <circle cx="226" cy="176" r="1.5" opacity="0.6"></circle>
    <circle cx="247" cy="168" r="1.5" opacity="0.9"></circle>
    <circle cx="266" cy="160" r="1.5" opacity="0.5"></circle>
    <circle cx="285" cy="166" r="1.5" opacity="0.8"></circle>
    <circle cx="304" cy="176" r="1.5" opacity="0.6"></circle>
    <circle cx="322" cy="186" r="1.5" opacity="0.4"></circle>
    <circle cx="238" cy="200" r="1.5" opacity="0.7"></circle>
    <circle cx="258" cy="194" r="1.5" opacity="0.5"></circle>
    <circle cx="278" cy="190" r="1.5" opacity="0.9"></circle>
    <circle cx="297" cy="200" r="1.5" opacity="0.6"></circle>
    <circle cx="315" cy="212" r="1.5" opacity="0.5"></circle>
    <circle cx="250" cy="222" r="1.5" opacity="0.8"></circle>
    <circle cx="272" cy="218" r="1.5" opacity="0.4"></circle>
    <circle cx="292" cy="228" r="1.5" opacity="0.6"></circle>
  </g>

  <!-- accent points (max 3) -->
  <g fill="var(--accent)" stroke="none">
    <circle cx="262" cy="131" r="2.2"></circle>
    <circle cx="296" cy="182" r="2.2"></circle>
    <circle cx="246" cy="214" r="2.2"></circle>
  </g>
</svg>
